# Copy to .env (or use ../monitoring/.env) and fill in real values.

# Router credentials (NDM CLI / dropbear)
ROUTER_HOST=192.168.1.1
ROUTER_PORT=23
ROUTER_USER=admin
ROUTER_PASS=

# sing-box healthcheck Clash API bearer token
# (used by sub_to_singbox.py and S99singbox-healthcheck on the router)
SINGBOX_HEALTHCHECK_SECRET=
